# Copy to .env and fill in. .env is git-ignored.

# OpenAI — used for BOTH embeddings and answer generation.
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Claude / Anthropic — optional; only needed if RAG_GENERATION_PROVIDER=anthropic.
# https://platform.claude.com/
# ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI — optional alternative embeddings provider.
# https://www.voyageai.com/
# VOYAGE_API_KEY=pa-...

# ---- Vector store backend ----
# RAG_STORE_BACKEND=numpy                # numpy (local .npz file) | pgvector (Supabase/Postgres)
# RAG_PG_TABLE=rag_chunks
# RAG_ANALYTICS=true                     # log questions + answered/abstained per workspace
#
# For Supabase: Project → Settings → Database → Connection string (URI).
# Enable the "vector" extension once under Database → Extensions.
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# ---- Bot personality ----
# RAG_BOT_NAME=Assistant
# RAG_BOT_PERSONA=You are Ava, a warm and concise support agent for Acme Inc.

# ---- Search quality ----
# RAG_HYBRID=true                        # fuse dense + BM25/full-text (Reciprocal Rank Fusion)
# RAG_CANDIDATE_K=30                     # candidates pulled before fusion/rerank
# RAG_RERANK=true                        # rerank candidates before they hit the prompt
# RAG_RERANK_PROVIDER=llm                # llm | none
# RAG_RERANK_MODEL=gpt-4o-mini

# ---- Models (defaults live in src/rag_pipeline/config.py) ----
# RAG_GENERATION_PROVIDER=openai         # openai | anthropic
# RAG_GENERATION_MODEL=gpt-4o-mini       # or gpt-4o / claude-opus-4-8 (if anthropic)
# RAG_EMBEDDING_PROVIDER=openai          # openai | voyage | hash (hash = offline, no key)
# RAG_EMBEDDING_MODEL=text-embedding-3-small   # or text-embedding-3-large / voyage-3
# RAG_CHUNK_TOKENS=512
# RAG_CHUNK_OVERLAP=64
# RAG_TOP_K=5
# RAG_EFFORT=high                        # low | medium | high | xhigh | max
# RAG_STORE_PATH=store/index.npz
